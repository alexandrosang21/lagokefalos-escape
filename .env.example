# Postgres connection string — Neon (https://neon.tech, free tier) in production,
# or any local Postgres for development. Without it the game still runs; the
# leaderboard just shows as offline.
DATABASE_URL=

# Signs the run-start tokens used for score validation.
# Generate with: openssl rand -base64 32  (REQUIRED in production)
APP_SECRET=

# Public URL of the deployed app (used for OG meta tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000
